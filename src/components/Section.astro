---
interface Props {
  title?: string;
  id?: string;
}
const { title, id } = Astro.props;
---

<section id={id}>
    {title && <h2>{title}</h2>}
    <slot/>
</section>

<style>
    section{
        max-width: 700px;
        margin: 0 auto 2rem auto;
        scroll-margin-top: 2rem;
    }
    h2 {
        margin-bottom: 8px;
        font-weight: 700;
        line-height: 1.5;
        font-size: 1.5rem;
    }
</style>