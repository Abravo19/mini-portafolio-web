---
import WorldMap from "@/icons/WorldMap.astro";
import Section from "../Section.astro";

import { work } from "@cv"
import { startsWithDotDotSlash } from "node_modules/astro/dist/core/path";
---

<Section title="Experience">
    <ul>
        {work.map(({name, startDate, endDate, position, summary, highlights}) => {
            const startYear = new Date(startDate).getFullYear();
            const endYear = endDate !== null ? new Date(endDate).getFullYear() : "Present";
            const years = `${startYear}- ${endYear}`


           
            return(
            <li>
                <article>
                    <header>
                        <div>
                    <h3>{name}</h3>
                    <h4>{position}</h4>
                        </div>
                        <time>
                            {years}
                        </time>
                    </header>
                    <footer>
                        <p>{summary}</p>
                    </footer>
                </article>
            </li>
            )
        }
    )
}
    </ul>
</Section>

<style>
    ul {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }
</style>
