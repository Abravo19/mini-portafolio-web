---
import Section from "../Section.astro";

import { projects } from "@cv"
---

<Section title="Projects">

    <ul>
        {
        projects.map(({url, description, highlights, name}) => 
        {    
            return (
                <li>
                    <article>
                        <header>
                            <h3>
                            <a href={url} title={'Voir le proyect ${name}'}>
                                {name}
                                </h3>
                            </a>
                            <p>{description}</p>
                        </header>
                        <footer>
                            <ul>
                                {highlights.map((highlight) => {
                                    return (
                                    <span>{highlight}</span>
                                    )
                                })
                                }
                            </ul>
                        </footer>
                    </article>
                </li>
            )
        })
    </ul>
</Section>

<style>
    ul{
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax (200px, 1fr));
        gap: 1rem;
    }

    article{
        border-radius: 8px;
        border: 1px solid #ddd;
        gap: 16px;
        display: flex;
        flex-direction: column;
        padding: 16px;
        height: 100%;
    }

    article headder{
        flex1;
    }

    article h3{
        margin-bottom: 4xp;
    }

    article a{
        text-decoration: underline;
    }

    article p{
        font-size: 0.8rem;
        line-height: 1.2rem;
        margin-bottom: 4px;
    }


    footer{
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        font-size: 0.6rem;
    }

    footer span{
        border-radius: 6xp;
        background: #eee;
        color: black;
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.2rem .6rem;
    }
</style>
