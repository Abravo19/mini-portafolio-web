<style>
  .download-container {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: flex-end;
  }

  .download-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background-color: #f1f5f9;
    color: #1e293b;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    border: 1px solid #e2e8f0;
  }

  .download-link:hover {
    background-color: #e2e8f0;
    color: #0f172a;
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .icon {
    color: #475569;
  }

  .table-container {
    overflow-x: auto;
    margin-top: 1rem;
    background: white;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    text-align: left;
  }

  th,
  td {
    padding: 12px;
    border-bottom: 1px solid #f1f5f9;
  }

  th {
    background-color: #f8fafc;
    font-weight: 600;
    color: #475569;
    vertical-align: bottom;
    white-space: nowrap;
  }

  td {
    color: #64748b;
    vertical-align: top;
  }

  strong {
    color: #1e293b;
    font-weight: 600;
  }

  .project-link {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
  }

  .project-link:hover strong {
    color: #0284c7;
    text-decoration: underline;
  }

  .check {
    text-align: center;
    font-weight: bold;
    color: #0284c7;
    font-size: 1rem;
  }

  /* Filas de encabezado de sección */
  .section-header td {
    background-color: #e8f0fe;
    color: #1e3a5f;
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 8px 12px;
    border-top: 2px solid #bfdbfe;
  }

  /* Efecto hover profesional al pasar el ratón */
  tbody tr:not(.section-header):hover {
    background-color: #f8fafc;
  }

  @media (width <= 700px) {
    table {
      font-size: 0.75rem;
    }

    th,
    td {
      padding: 8px;
    }
  }
</style>
