---
import { basics } from "@cv";
const { name, label } = basics;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`${label}. Portfolio de ${name}.`} />
    <meta property="og:title" content={`${name} - CV`} />
    <meta property="og:description" content={label} />
    <meta property="og:type" content="website" />
    <title>{name} - CV</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family:
      menlo,
      monaco,
      Lucida Consola,
      "Courier New",
      monospace;
    background-color: #fff;
    letter-spacing: -0.025em;
  }
  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: #333;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
  }

  @media print {
    .no-print {
      display: none;
    }
  }

  .print {
    display: none !important;
  }

  @media print {
    .print {
      display: block !important;
    }
  }
</style>
